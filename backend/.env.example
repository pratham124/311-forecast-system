APP_ENV=development
# Match Docker host port (use 5433 in the URL if you set POSTGRES_PORT=5433 for compose)
DATABASE_URL=postgresql+psycopg2://forecast_user:forecast_pass@localhost:5432/forecast_system
EDMONTON_311_SOURCE_NAME=edmonton_311
EDMONTON_311_API_URL=https://data.edmonton.ca/resource/q7ua-agfg.json
EDMONTON_311_API_TOKEN=
JWT_SECRET=test-secret-key-311-forecast-system-32b
JWT_AUDIENCE=311-forecast-system
JWT_ISSUER=311-forecast-system
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14
AUTH_SIGNUP_ALLOWLIST=sitoula@ualberta.ca:CityPlanner,manager@example.com:OperationalManager
AUTH_REFRESH_COOKIE_NAME=forecast_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
FRONTEND_ORIGIN=http://localhost:5173
# Local development also accepts the matching http://127.0.0.1:5173 origin automatically.
SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 0 * * 0
EDMONTON_311_FIRST_RUN_LOOKBACK_DAYS=1095
